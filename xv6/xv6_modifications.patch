diff -ruN xv6-original/user/schedulertest.c xv6-riscv/user/schedulertest.c
--- xv6-original/user/schedulertest.c	1970-01-01 05:30:00.000000000 +0530
+++ xv6-riscv/user/schedulertest.c	2025-09-11 22:46:26.656980655 +0530
@@ -0,0 +1,28 @@
+#include "kernel/types.h"
+#include "kernel/stat.h"
+#include "user/user.h"
+
+int main(int argc, char *argv[]) {
+    int pid;
+
+    // Fork multiple processes to test scheduler
+    for(int i = 0; i < 3; i++){
+        pid = fork();
+        if(pid == 0){
+            // Child process: do some work
+            for(int j = 0; j < 5; j++){
+                printf("PID %d running iteration %d\n", getpid(), j);
+                for(volatile int k = 0; k < 10000000; k++); // busy loop
+            }
+            exit(0);
+        }
+    }
+
+    // Parent waits for children
+    for(int i = 0; i < 3; i++){
+        wait(0);
+    }
+
+    printf("Scheduler test done\n");
+    exit(0);
+}
